generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FARMER
  BUYER
  ADMIN
}

enum Language {
  RU
  TJ
}

enum MarketStatus {
  ACTIVE
  SOLD
  HIDDEN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                String              @id @default(cuid())
  fullName          String
  phone             String              @unique
  email             String              @unique
  passwordHash      String
  region            String?
  district          String?
  role              Role                @default(FARMER)
  language          Language            @default(RU)
  avatarUrl         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  diagnosisHistory  DiagnosisHistory[]
  irrigationHistory IrrigationHistory[]
  marketProducts    MarketProduct[]
  aiChatMessages    AiChatMessage[]
  marketAdvice      MarketPriceAdvice[]
  adminLogs         AdminLog[]          @relation("AdminLogs")

  @@index([role])
  @@index([createdAt])
}

model Region {
  id                String              @id @default(cuid())
  name              String              @unique
  nameTj            String
  latitude          Float
  longitude         Float
  createdAt         DateTime            @default(now())
  diagnosisHistory  DiagnosisHistory[]
  irrigationHistory IrrigationHistory[]
  marketProducts    MarketProduct[]

  @@index([name])
}

model Crop {
  id                String              @id @default(cuid())
  nameRu            String
  nameTj            String
  season            String
  wateringGuideRu   String
  wateringGuideTj   String
  commonDiseasesRu  String
  commonDiseasesTj  String
  careTipsRu        String
  careTipsTj        String
  harvestTimeRu     String
  harvestTimeTj     String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  diseases          Disease[]
  diagnosisHistory  DiagnosisHistory[]
  irrigationHistory IrrigationHistory[]
  marketProducts    MarketProduct[]

  @@index([nameRu])
  @@index([nameTj])
}

model Disease {
  id           String    @id @default(cuid())
  cropId       String
  nameRu       String
  nameTj       String
  symptomsRu   String
  symptomsTj   String
  treatmentRu  String
  treatmentTj  String
  riskLevel    RiskLevel @default(MEDIUM)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  crop         Crop      @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@index([cropId])
  @@index([riskLevel])
}

model DiagnosisHistory {
  id              String    @id @default(cuid())
  userId          String
  cropId          String
  regionId        String
  photoUrl        String
  detectedProblem String
  confidence      Float
  riskLevel       RiskLevel @default(MEDIUM)
  aiAdviceJson    Json
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop            Crop      @relation(fields: [cropId], references: [id], onDelete: Restrict)
  region          Region    @relation(fields: [regionId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([cropId])
  @@index([regionId])
  @@index([riskLevel])
}

model IrrigationHistory {
  id              String   @id @default(cuid())
  userId          String
  cropId          String
  regionId        String
  soilType        String
  growthStage     String
  fieldSize       Float
  dripIrrigation  Boolean  @default(false)
  aiAdviceJson    Json
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop            Crop     @relation(fields: [cropId], references: [id], onDelete: Restrict)
  region          Region   @relation(fields: [regionId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([cropId])
  @@index([regionId])
}

model MarketProduct {
  id             String              @id @default(cuid())
  userId         String
  cropId         String
  title          String
  description    String
  price          Decimal             @db.Decimal(12, 2)
  quantity       Float
  unit           String
  regionId       String
  district       String
  phone          String
  photoUrl       String?
  status         MarketStatus        @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop           Crop                @relation(fields: [cropId], references: [id], onDelete: Restrict)
  region         Region              @relation(fields: [regionId], references: [id], onDelete: Restrict)
  priceAdvice    MarketPriceAdvice[]

  @@index([userId, createdAt])
  @@index([cropId])
  @@index([regionId])
  @@index([status])
  @@index([title])
}

model AiChatMessage {
  id        String   @id @default(cuid())
  userId    String
  question  String
  answer    String
  language  Language @default(RU)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([language])
}

model MarketPriceAdvice {
  id         String        @id @default(cuid())
  userId     String
  productId  String
  adviceJson Json
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    MarketProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([productId])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}
